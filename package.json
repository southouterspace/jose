{
  "name": "jose",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "typescript": "^6.0.3",
      "@types/bun": "^1.3.14"
    }
  },
  "scripts": {
    "codegen": "bun run tooling/codegen/src/index.ts",
    "codegen:check": "bun run tooling/codegen/src/index.ts --check",
    "build": "bun run codegen && turbo run build",
    "test": "turbo run test",
    "lint": "biome check",
    "format": "biome check --write",
    "typecheck": "bun run codegen && turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "turbo": "^2.10.0",
    "typescript": "catalog:",
    "ultracite": "^7.8.3"
  }
}
